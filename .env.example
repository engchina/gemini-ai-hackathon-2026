# Gemini API Key (获得自 Google AI Studio)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 运行端口 (本地默认 8080)
PORT=8080

# 日志输出级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG
# Gemini Model to use (gemini-3.5-flash is the default. Note: Free tier has a 20 RPD limit; billing activation is required for higher usage)
GEMINI_MODEL=gemini-3.5-flash
